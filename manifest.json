{
  "manifest_version": 3,
  "name": "DiyyMotion",
  "version": "1.3.2",
  "description": "DiyyMotion by @diyy4a__: private TikTok creator tools with local video processing and no activation.",
  "permissions": [
    "cookies",
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.byteoversea.com/*",
    "https://tiktok.com/*",
    "https://tiktokcdn.com/*",
    "https://byteoversea.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "diyymotion@diyy4a.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_title": "DiyyMotion",
    "default_popup": "dashboard.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://tiktok.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": [
        "content/main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.tiktok.com/tiktokstudio/*",
        "https://www.tiktok.com/upload*",
        "https://www.tiktok.com/creator-center*",
        "https://studio.tiktok.com/*"
      ],
      "css": [
        "content/studio.css"
      ],
      "js": [
        "content/studio.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.tiktok.com/@*",
        "https://www.tiktok.com/profile*"
      ],
      "css": [
        "content/profile.css"
      ],
      "js": [
        "content/profile.js"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://www.tiktok.com/@*/video/*"
      ]
    },
    {
      "matches": [
        "https://www.tiktok.com/@*/video/*"
      ],
      "css": [
        "content/video.css"
      ],
      "js": [
        "content/video.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/mp4.js",
        "assets/logo.png",
        "lib/ffmpeg/ffmpeg-worker.js",
        "lib/ffmpeg/ffmpeg-core.js",
        "lib/ffmpeg/ffmpeg-core.wasm",
        "lib/ffmpeg/ffmpeg-client.js"
      ],
      "matches": [
        "https://*.tiktok.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
